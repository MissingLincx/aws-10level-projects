
# Local .terraform directories (contains downloaded binaries/plugins)
**/.terraform/*

# .tfstate files contain the absolute blueprint and map of your cloud layout.
# CRITICAL: These can occasionally contain plain-text secrets/passwords!
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all variable files containing actual environment configurations or passwords
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override directories
.terraform.lock.hcl

# Hidden AWS credentials path if you ever store it locally in the project (don't!)
.aws/
secrets.tfvars
